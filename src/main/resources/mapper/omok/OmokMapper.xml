<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.crown.omok.mapper.OmokMapper">

    <resultMap id="gameRoomResultMap" type="com.crown.omok.dto.GameRoomDto">
        <id     property="roomId"           column="room_id"/>
        <result property="blackMemberId"    column="black_member_id"/>
        <result property="whiteMemberId"    column="white_member_id"/>
        <result property="status"           column="status"/>
        <result property="winnerId"         column="winner_id"/>
        <result property="blackScoreChange" column="black_score_change"/>
        <result property="whiteScoreChange" column="white_score_change"/>
        <result property="createdAt"        column="created_at"/>
        <result property="finishedAt"       column="finished_at"/>
    </resultMap>

    <insert id="insertRoom">
        INSERT INTO game_room (black_member_id, white_member_id)
        VALUES (#{blackMemberId}, #{whiteMemberId})
    </insert>

    <select id="findLatestRoom" resultMap="gameRoomResultMap">
        SELECT * FROM game_room
        WHERE black_member_id = #{blackMemberId}
          AND white_member_id = #{whiteMemberId}
        ORDER BY created_at DESC
        LIMIT 1
    </select>

    <select id="findRoomById" resultMap="gameRoomResultMap">
        SELECT * FROM game_room WHERE room_id = #{roomId}
    </select>

    <update id="finishRoom">
        UPDATE game_room
        SET status      = 'FINISHED',
            winner_id   = #{winnerId},
            finished_at = NOW()
        WHERE room_id = #{roomId}
    </update>

    <insert id="insertMove">
        INSERT INTO game_move (room_id, member_id, move_x, move_y, move_order)
        VALUES (#{roomId}, #{memberId}, #{moveX}, #{moveY}, #{moveOrder})
    </insert>

    <select id="findHistoryByMemberId" resultMap="gameRoomResultMap">
        SELECT * FROM game_room
        WHERE black_member_id = #{memberId}
           OR white_member_id = #{memberId}
        ORDER BY created_at DESC
    </select>

</mapper>
